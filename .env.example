APP_ENV=local

# Postgres
POSTGRES_DB=concierge
POSTGRES_USER=concierge
POSTGRES_PASSWORD=concierge
DATABASE_URL=postgresql+asyncpg://concierge:concierge@postgres:5432/concierge

# Redis
REDIS_URL=redis://redis:6379/0

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token
VAULT_SERVICE_AUTH_PATH=concierge/service-auth

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LLM (hosted API — no torch)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-70b-versatile
EMBEDDING_MODEL=embed-english-v3.0
# Owner B providers (Groq for LLM, Cohere for embeddings). Leave empty here
# and put real values in .env; production reads them from Vault.
GROQ_API_KEY=
COHERE_API_KEY=
# Legacy / alt providers — leave empty unless used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

# Internal service URLs
MODEL_SERVER_URL=http://model_server:8001
GUARDRAILS_URL=http://guardrails_sidecar:8002
API_BASE_URL=http://api:8000

# Secrets — local-dev fallbacks only.
# In all other envs these are read from Vault (secret/concierge).
SERVICE_AUTH_SECRET=change-me-local-dev-only
WIDGET_TOKEN_SECRET=change-me-local-dev-only
JWT_SECRET=change-me-local-dev-only

# Router / Agent / Memory (Owner B). Defaults below mirror the frozen specs.
ROUTER_CONFIDENCE_THRESHOLD=0.6
CLASSIFIER_ENABLED=false
AGENT_MAX_TOOL_ITERATIONS=3
AGENT_MAX_OUTPUT_TOKENS=1024
MEMORY_TTL_SECONDS=1800
MEMORY_MAX_ENTRIES=40

# Widget session token (Spec 011 FR-012).
WIDGET_TOKEN_TTL_SECONDS=900

# capture_lead per-session rate limit (Spec 012 FR-003).
LEAD_CAPTURE_LIMIT_PER_SESSION=5
LEAD_CAPTURE_WINDOW_HOURS=1
