APP_ENV=local

# Postgres
DATABASE_URL=postgresql+asyncpg://concierge:concierge@postgres:5432/concierge

# Redis
REDIS_URL=redis://redis:6379/0

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LLM (hosted API — no torch)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Internal service URLs
MODEL_SERVER_URL=http://model_server:8001
GUARDRAILS_URL=http://guardrails_sidecar:8002

# Secrets (resolve from Vault in non-local envs)
SERVICE_AUTH_SECRET=change-me-local-dev-only
WIDGET_TOKEN_SECRET=change-me-local-dev-only
