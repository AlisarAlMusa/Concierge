APP_ENV=local

# Postgres
POSTGRES_DB=concierge
POSTGRES_USER=concierge
POSTGRES_PASSWORD=concierge
DATABASE_URL=postgresql+asyncpg://concierge:concierge@postgres:5432/concierge

# Redis
REDIS_URL=redis://redis:6379/0

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token
VAULT_SERVICE_AUTH_PATH=concierge/service-auth

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LLM (hosted API — no torch)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# API keys — leave empty here; set in .env and they are seeded into Vault automatically
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Azure OpenAI — leave empty if not using Azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

# Internal service URLs
MODEL_SERVER_URL=http://model_server:8001
GUARDRAILS_URL=http://guardrails_sidecar:8002

# Secrets — local-dev fallbacks only.
# In all other envs these are read from Vault (secret/concierge).
SERVICE_AUTH_SECRET=change-me-local-dev-only
WIDGET_TOKEN_SECRET=change-me-local-dev-only
JWT_SECRET=change-me-local-dev-only
